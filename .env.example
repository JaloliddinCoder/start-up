# Telegram Bot API credentials used by the registration form
# (src/components/RegistrationForm.jsx) to post new applications into a
# Telegram group/channel.
#
# 1. Create a bot via @BotFather on Telegram and copy the token it gives you.
# 2. Add the bot to your target group/channel as an admin.
# 3. Get the group/channel's chat id (e.g. via @RawDataBot, or by calling
#    https://api.telegram.org/bot<token>/getUpdates after sending a message
#    in the group).
# 4. Copy this file to .env.local and fill in real values — .env.local is
#    gitignored so your token never gets committed.

VITE_TELEGRAM_BOT_TOKEN=your-bot-token-here
VITE_TELEGRAM_CHAT_ID=your-group-or-channel-chat-id-here
